{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tos.local/students/student-profile.schema.json",
  "title": "TOS student profile (roster) — PII/ePHI",
  "description": "A student profile keyed by the school student_id, with guardians (to contact home) and health_plans (ePHI — e.g. an anaphylaxis action plan stating when/where to administer epinephrine). REPO RULE: any tracked/committed file using this schema MUST use placeholders only; real data lives only in the gitignored local store or a live SIS. Policy + precedence/conflict rules: student-data-policy.md.",
  "type": "object",
  "required": ["students"],
  "properties": {
    "_comment": {"type": "string"},
    "version": {"type": "string"},
    "updated": {"type": "string"},
    "is_placeholder": {"type": "boolean", "description": "true for the committed example; real stores set false"},
    "students": {"type": "array", "items": {"$ref": "#/$defs/profile"}}
  },
  "$defs": {
    "profile": {
      "type": "object",
      "required": ["student_id"],
      "properties": {
        "student_id": {"type": "string", "description": "unique school identifier (the join key)"},
        "first_name": {"type": "string"},
        "last_name": {"type": "string"},
        "preferred_name": {"type": "string"},
        "grade": {"type": "string"},
        "guardians": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {"type": "string"},
              "relationship": {"type": "string"},
              "phone": {"type": "string"},
              "email": {"type": "string"},
              "is_emergency_contact": {"type": "boolean"},
              "primary": {"type": "boolean"},
              "contact_preferences": {"type": "string"}
            }
          }
        },
        "plan_flags": {
          "type": "object",
          "properties": {
            "iep": {"type": "boolean"},
            "section_504": {"type": "boolean"},
            "ell": {"type": "boolean"},
            "gifted": {"type": "boolean"},
            "medical_action_plan": {"type": "boolean"},
            "behavior_plan": {"type": "boolean"}
          }
        },
        "health_plans": {
          "type": "array",
          "description": "ePHI — safety-critical. Surface from the student's ACTUAL signed plan; never fabricate.",
          "items": {
            "type": "object",
            "required": ["condition"],
            "properties": {
              "condition": {"type": "string"},
              "severity": {"type": "string"},
              "action_plan_ref": {"type": "string"},
              "medications": {"type": "array", "items": {"type": "string"}},
              "emergency_protocol": {"type": "string"},
              "when_where_to_administer": {"type": "string"},
              "signed_by": {"type": "string"},
              "effective_dates": {"type": "string"},
              "source": {"type": "string"}
            }
          }
        },
        "provenance": {"type": "string", "description": "where this record came from (sis | local | teacher-entered)"},
        "last_verified": {"type": "string"},
        "access": {
          "type": "object",
          "properties": {
            "minimum_necessary": {"type": "boolean"},
            "note": {"type": "string"}
          }
        }
      }
    }
  }
}
