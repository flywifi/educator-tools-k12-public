{
  "_comment": "Declarative workflow definition for assessment-designer.",
  "id": "assessment-designer",
  "description": "Assessment with aligned items, answer key, and reading-level check",
  "steps": [
    {"step": 1, "atom": "atom-standards-match",   "input_from": "teacher request",    "output_to": "step2"},
    {"step": 2, "atom": "atom-misconception",     "input_from": "step1.standards",    "output_to": "step3"},
    {"step": 3, "atom": "atom-assessment-item",   "input_from": "step1.standards",    "output_to": "step4", "repeat": "n_items"},
    {"step": 4, "atom": "atom-reading-level",     "input_from": "step3.item_text",    "output_to": "step5", "repeat": "per_item"},
    {"step": 5, "atom": "atom-differentiate",     "input_from": "step3.items",        "output_to": "step6", "repeat": "per_profile"},
    {"step": 6, "atom": "atom-quality-check",     "input_from": "assembled_assessment","output_to": "final", "gates": ["standard_alignment", "dok_appropriate", "reading_level"]}
  ],
  "shortcut_atoms": ["atom-assessment-item", "atom-standards-match"]
}
