{
  "_comment": "Declarative workflow definition for special-education-support.",
  "id": "special-education-support",
  "description": "IEP goal drafting, accommodation plans, and differentiated materials for SPED contexts",
  "steps": [
    {"step": 1, "atom": "atom-standards-match",  "input_from": "teacher request",   "output_to": "step2"},
    {"step": 2, "atom": "atom-iep-goal",         "input_from": "plop + step1",      "output_to": "step3"},
    {"step": 3, "atom": "atom-differentiate",    "input_from": "content + profile", "output_to": "step4"},
    {"step": 4, "atom": "atom-quality-check",    "input_from": "assembled_artifact","output_to": "final", "gates": ["standard_alignment", "student_data_policy"]}
  ],
  "shortcut_atoms": ["atom-iep-goal", "atom-differentiate"]
}
