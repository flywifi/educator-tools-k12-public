# Build artifacts
dist/
*.skill

# Python
__pycache__/
*.pyc

# OS
.DS_Store

# TOS: real student data (PII/ePHI) — never commit; placeholders only in tracked files
shared/students/students.local.json
shared/students/local/
*.students.local.json
shared/records/records.local.json
shared/records/local/
*.records.local.json

# TOS: teacher operating profiles — the teacher's own data; only teacher.example.json is committed
shared/context/profiles/teacher.local.json
shared/context/profiles/*.local.json

# TOS: staff directory — staff personal data; only staff.example.json is committed (gated, authorized-first)
shared/staff/staff.local.json
shared/staff/local/
*.staff.local.json

# TOS: cloud-provider API keys / secrets — env only, NEVER commit (see shared/health/dependency-policy.md)
.env
*.env
secrets.json
*.secrets.json
*.local.env
